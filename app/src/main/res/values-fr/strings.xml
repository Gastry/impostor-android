    <string name="how_preparation_title">Préparation</string>
    <string name="how_preparation_line_1">Choisissez le nombre de joueurs et les catégories pour préparer la partie.</string>
    <string name="how_preparation_line_2">L’application distribue les rôles avec un seul téléphone.</string>
    <string name="how_preparation_line_3">Chaque joueur regarde en secret puis passe le téléphone.</string>
    <string name="how_play_title">Déroulement de la manche</string>
    <string name="how_play_line_1">Quand tout le monde a vu son rôle, laissez le téléphone de côté.</string>
    <string name="how_play_line_2">À chaque tour, chaque joueur dit exactement 1 mot lié au mot secret.</string>
    <string name="how_play_line_3">La base recommandée est de faire 2 tours avant le vote ; ajoutez-en un troisième seulement si le groupe manque encore d’informations.</string>
    <string name="how_play_line_4">L’app ne gère pas les tours de parole ; le groupe s’en charge.</string>
    <string name="how_win_title">Comment gagner</string>
    <string name="how_win_line_1">Après 2 tours, ou 3 si le groupe manque encore d’informations, votez pour la personne que vous pensez être l’imposteur.</string>
    <string name="how_win_line_2">Si le groupe le trouve, les civils gagnent.</string>
    <string name="how_win_line_3">Si le groupe se trompe, l’imposteur gagne.</string>
    <string name="how_win_line_4">Variante optionnelle : s’il est découvert, l’imposteur peut faire égalité en devinant le mot (non géré par l’app).</string>
    <string name="how_tips_title">Conseils de jeu</string>
    <string name="how_tip_1">Ne donnez pas un indice trop évident.</string>
    <string name="how_tip_2">2 tours est généralement le meilleur point de départ ; ajoutez-en un troisième seulement si le groupe manque encore d’informations.</string>
    <string name="how_tip_3">Observez les réactions et les réponses des autres.</string>

